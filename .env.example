DATABASE_URL=postgresql+asyncpg://DB_USER:DB_PASSWORD@localhost:5432/DB_NAME
POSTGRES_USER=DB_USER
POSTGRES_PASSWORD=DB_PASSWORD
POSTGRES_DB=DB_NAME

JWT_SECRET=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=43200
GOOGLE_CLIENT_ID=your_google_client_id_here

CHAT_PROVIDER=your_provider
EMBEDDING_PROVIDER=your_provider

CHAT_BASE_URL=your_chat_base_url
EMBEDDING_BASE_URL=your_embedding_base_url

CHAT_API_KEY=your_chat_api_key
EMBEDDING_API_KEY=your_embedding_api_key
PROVIDER_CONFIG_ENCRYPTION_KEY=your_encryption_key_here

CHAT_MODEL=your_chat_model
CHAT_FALLBACK_MODEL=your_chat_fallback_model
CHAT_PROVIDER_CHAIN=gemini,groq,openrouter,ollama

EMBEDDING_MODEL=your_embedding_model
EMBEDDING_DIM = 768
EMBEDDING_PROVIDER_CHAIN=openrouter,gemini,ollama

PROVIDER_MAX_RETRIES=2
PROVIDER_RETRY_BASE_DELAY_SECONDS=1
PROVIDER_REQUEST_TIMEOUT_SECONDS=60
PROVIDER_FAILURE_THRESHOLD=3
PROVIDER_COOLDOWN_SECONDS=60

STORAGE_PROVIDER=your_storage_provider
AWS_S3_BUCKET=your_aws_s3_bucket

AWS_REGION=your_aws_region

# Celery broker (Redis). Redis must never be exposed on a public port --
# only the API and worker processes should be able to reach it.
CELERY_BROKER_URL=redis://localhost:6379/0
# When running the API inside Docker Compose
# Use Docker service names instead:
# CELERY_BROKER_URL=redis://redis:6379/0
